# ─────────────────────────────────────────────────────────────────────────────
# EduMentor Voice — Environment Variables Reference
# Copy this file to .env and fill in the values marked with <CHANGE_ME>.
# Lines starting with # are comments and are ignored at runtime.
# ─────────────────────────────────────────────────────────────────────────────


# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=development          # development | production
APP_VERSION=dev              # Shown in /health endpoint
LOG_LEVEL=INFO               # DEBUG | INFO | WARNING | ERROR

# ── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
ENVIRONMENT=development      # development | production (controls secure cookies)

# ── STT — faster-whisper ──────────────────────────────────────────────────────
WHISPER_MODEL=small.en       # tiny.en | base.en | small.en | medium.en | large-v3
WHISPER_BEAM_SIZE=2
WHISPER_CORRECTION_THRESHOLD=-0.5
WHISPER_CORRECTION_TIMEOUT=0.4
WHISPER_CORRECTION_MAX_TOKENS=20
FUZZY_MATCH_THRESHOLD=80.0
VOCAB_PATH=speech/data/engineering_vocab.json

# ── VAD — Silero ──────────────────────────────────────────────────────────────
VAD_ENGINE=silero
VAD_THRESHOLD=0.45
VAD_SILENCE_TIMEOUT=0.5
MIN_SPEECH_DURATION=0.15
LIVE_TRANSCRIPTION_INTERVAL=0.7

# ── Semantic Endpointing ──────────────────────────────────────────────────────
ENDPOINTING_MODE=fixed       # fixed | semantic
ENDPOINT_MIN_SILENCE_MS=250
ENDPOINT_MAX_SILENCE_MS=1200
ENDPOINT_CHECK_INTERVAL_MS=100

# ── LLM — llama.cpp local server ─────────────────────────────────────────────
LLM_BASE_URL=http://127.0.0.1:8080
LLM_MODEL_NAME=local
LLM_MAX_TOKENS=512
LLM_TEMPERATURE=0.55
LLM_TOP_P=0.9
LLM_REPEAT_PENALTY=1.1
LLM_TIMEOUT=120
LLM_CALL_TIMEOUT_SECONDS=8

# ── TTS — Kokoro ──────────────────────────────────────────────────────────────
KOKORO_VOICE=af_heart
KOKORO_SPEED=1.0
KOKORO_LANG_CODE=a           # a = American English | b = British English
TTS_CHUNK_CHARS=120

# ── Agent Layer ───────────────────────────────────────────────────────────────
AGENT_ENABLED=true
AGENT_INTENT_CLASSIFY=true
AGENT_SAFETY_ENABLED=true

# ── Memory ────────────────────────────────────────────────────────────────────
MEMORY_MAX_TURNS=10
MEMORY_BACKEND=memory        # memory | sqlite | redis

# ── Session Summarizer ────────────────────────────────────────────────────────
# SESSION_SUMMARY_DIR=backend/data/session_summaries

# ── Student Profile ───────────────────────────────────────────────────────────
# STUDENT_PROFILE_PATH=backend/data/student_profile.json

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_ENABLED=false
DATABASE_URL=                # postgresql+asyncpg://user:password@host:5432/dbname
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=<CHANGE_ME>
POSTGRES_DB=edumentor
POSTGRES_POOL_SIZE=5

# ── Authentication ────────────────────────────────────────────────────────────
JWT_SECRET=<CHANGE_ME>       # Use a long, random string in production
JWT_ALGORITHM=HS256
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# ── SMTP (email verification) ─────────────────────────────────────────────────
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@edumentor.edu

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=20
RATE_LIMIT_DAILY_REQUESTS=500
MAX_CONNECTIONS_PER_IP=3
RATE_LIMIT_BYPASS_TOKEN=     # Leave empty to disable bypass
MAX_DAILY_TOKENS=100000
MAX_CONTEXT_TOKENS=4000
MAX_DAILY_TTS_CHARS=50000
VOICE_RATE_LIMIT_PER_MINUTE=12
VOICE_BURST_MAX_IN_5S=3

# ── Circuit Breaker ───────────────────────────────────────────────────────────
CIRCUIT_FAILURE_THRESHOLD=3
CIRCUIT_RECOVERY_TIMEOUT=30

# ── Audio Guards ──────────────────────────────────────────────────────────────
MAX_AUDIO_CHUNK_BYTES=1000000
MAX_UTTERANCE_SECONDS=45
MIN_UTTERANCE_MS=200
HIGH_BAND_POWER_RATIO_THRESHOLD=0.40
MIN_UTTERANCE_WORDS=2
MIN_UTTERANCE_DURATION_MS=400

# ── Idempotency ───────────────────────────────────────────────────────────────
IDEMPOTENCY_WINDOW_SECONDS=1.0

# ── Multi-turn Jailbreak Guard ────────────────────────────────────────────────
MULTI_TURN_WINDOW_TURNS=5
MULTI_TURN_SIGNAL_THRESHOLD=3

# ── Logging ───────────────────────────────────────────────────────────────────
AGENT_LOG_LEVEL=INFO
# AGENT_LOG_FILE=backend/logs/agent.log

# ── Cloud Deployment (Hugging Face Spaces / ZeroGPU) ─────────────────────────
CLOUD_MODEL_ID=Qwen/Qwen2.5-1.5B-Instruct
CLOUD_MAX_TOKENS=250
