{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "datasource",
          "uid": "grafana"
        },
        "enable": true,
        "hide": true,
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "id": 1,
      "title": "Time to first token (p50/p95/p99)",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.5, rate(edumentor_llm_ttft_seconds_bucket[5m]))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, rate(edumentor_llm_ttft_seconds_bucket[5m]))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, rate(edumentor_llm_ttft_seconds_bucket[5m]))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth"
          },
          "unit": "s"
        }
      }
    },
    {
      "id": 2,
      "title": "Total turn latency (p50/p95/p99)",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "gridPos": {
        "x": 12,
        "y": 0,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.5, rate(edumentor_llm_total_latency_seconds_bucket[5m]))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, rate(edumentor_llm_total_latency_seconds_bucket[5m]))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, rate(edumentor_llm_total_latency_seconds_bucket[5m]))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth"
          },
          "unit": "s"
        }
      }
    },
    {
      "id": 3,
      "title": "Queue depth over time",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 8,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "edumentor_queue_depth",
          "legendFormat": "Queue Depth",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line"
          },
          "unit": "none"
        }
      }
    },
    {
      "id": 4,
      "title": "Enqueue vs rejected vs acked (rate)",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "gridPos": {
        "x": 12,
        "y": 8,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "rate(edumentor_queue_enqueued_total[5m])",
          "legendFormat": "Enqueued Rate",
          "refId": "A"
        },
        {
          "expr": "rate(edumentor_queue_rejected_total[5m])",
          "legendFormat": "Rejected Rate",
          "refId": "B"
        },
        {
          "expr": "rate(edumentor_queue_acked_total[5m])",
          "legendFormat": "Acked Rate",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line"
          },
          "unit": "pps"
        }
      }
    },
    {
      "id": 5,
      "title": "Stale job reclaims",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 16,
        "w": 6,
        "h": 6
      },
      "targets": [
        {
          "expr": "sum(increase(edumentor_queue_reclaimed_total[$__range]))",
          "legendFormat": "Stale Reclaims",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 0.1
              }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": ["sum"]
        }
      }
    },
    {
      "id": 6,
      "title": "Endpointing decisions by reason",
      "type": "piechart",
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "gridPos": {
        "x": 6,
        "y": 16,
        "w": 6,
        "h": 6
      },
      "targets": [
        {
          "expr": "sum by (reason) (increase(edumentor_endpoint_decision_total[$__range]))",
          "legendFormat": "{{reason}}",
          "refId": "A"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "right",
          "values": ["percent", "value"]
        },
        "tooltip": {
          "mode": "single"
        }
      }
    },
    {
      "id": 7,
      "title": "Celebrations triggered by emotion type",
      "type": "bargauge",
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "gridPos": {
        "x": 12,
        "y": 16,
        "w": 6,
        "h": 6
      },
      "targets": [
        {
          "expr": "sum by (emotion) (increase(edumentor_celebration_triggered_total[$__range]))",
          "legendFormat": "{{emotion}}",
          "refId": "A"
        }
      ],
      "options": {
        "displayMode": "basic",
        "orientation": "horizontal",
        "reduceOptions": {
          "values": true,
          "calcs": ["sum"]
        }
      }
    },
    {
      "id": 8,
      "title": "Memory recall hit rate",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "gridPos": {
        "x": 18,
        "y": 16,
        "w": 6,
        "h": 6
      },
      "targets": [
        {
          "expr": "sum(increase(edumentor_memory_recall_total{outcome=\"hit\"}[$__range])) / sum(increase(edumentor_memory_recall_total[$__range]))",
          "legendFormat": "Hit Rate",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.70
              },
              {
                "color": "green",
                "value": 0.90
              }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"]
        }
      }
    }
  ],
  "refresh": "5s",
  "schemaVersion": 38,
  "style": "dark",
